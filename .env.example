# Sakhi AI Frontend — environment variables
# Copy this file to .env.local and adjust values.

# Use demo/mock data when no backend is available (default: true).
# Set to false to connect to a live API at NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_USE_DEMO_MODE=true

# Backend API base URL (no trailing slash).
NEXT_PUBLIC_API_URL=https://api.sakhi.ai
